# Copy this file to .env or ~/.config/acrc-codex-skills/.env and fill in values.
# Never commit a real .env file.

# OpenAI, used by banner-proposal, banner-design-production, and banner-resizer.
OPENAI_API_KEY=

# Power Automate / SharePoint save flow, used by banner-proposal and banner-design-production.
PA_SAVE_RUN_URL=
PA_WORKFLOW_SECRET=

# Canvas acceptance evaluation, used by banner-proposal Phase 3.
# The skill calls the Canvas API directly; no credential CSV or local CLI is needed.
CANVAS_API_BASE_URL=https://mugen-ai-chat.jp
CANVAS_API_KEY=
CANVAS_COMPANY_ID=
CANVAS_AGENT_ID=
CANVAS_EXTERNAL_USER_ID=external_user_123
CANVAS_CONVERSATION_ID=

# Adobe Firefly, used by banner-resizer outpaint.
FIREFLY_CLIENT_ID=
FIREFLY_CLIENT_SECRET=

# Optional cache locations. Leave blank to use the current workspace .cache folder.
BANNER_PROPOSAL_CACHE_DIR=
BANNER_DESIGN_CACHE_DIR=
